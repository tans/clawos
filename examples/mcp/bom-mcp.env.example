# bom-mcp runtime paths
BOM_MCP_STATE_DIR=$HOME/.openclaw/state/bom-mcp
BOM_MCP_DB_PATH=$BOM_MCP_STATE_DIR/bom-mcp.sqlite
BOM_MCP_EXPORT_DIR=$BOM_MCP_STATE_DIR/exports
BOM_MCP_CACHE_DIR=$BOM_MCP_STATE_DIR/cache

# Optional public file base URL. Leave unset for file-only exports.
# Example:
# BOM_MCP_PUBLIC_BASE_URL=https://files.example.com/bom-mcp
BOM_MCP_PUBLIC_BASE_URL=
