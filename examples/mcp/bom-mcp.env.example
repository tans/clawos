# bom-mcp runtime paths
BOM_MCP_STATE_DIR=$HOME/.openclaw/state/bom-mcp
BOM_MCP_DB_PATH=$BOM_MCP_STATE_DIR/bom-mcp.sqlite
BOM_MCP_EXPORT_DIR=$BOM_MCP_STATE_DIR/exports
BOM_MCP_CACHE_DIR=$BOM_MCP_STATE_DIR/cache

# Optional public file base URL. Leave unset for file-only exports.
# Example:
# BOM_MCP_PUBLIC_BASE_URL=https://files.example.com/bom-mcp
BOM_MCP_PUBLIC_BASE_URL=

# Optional FX configuration for cross-currency supplier prices.
# bom-mcp will not auto-resolve a USD source into a CNY quote unless a rate is
# configured explicitly. Example:
# BOM_MCP_FX_USD_CNY=7.20
# Or use a JSON map:
# BOM_MCP_FX_RATES_JSON={"USD/CNY":7.20,"EUR/CNY":7.85}
BOM_MCP_FX_USD_CNY=
BOM_MCP_FX_RATES_JSON=

# Optional supplier session overrides for web pricing.
# Use these when a supplier requires login or browser challenge cookies.
# DigiKey also supports a dedicated CDP path. If set, bom-mcp will connect to
# this browser first and extract page content from the real browser session.
# If unset, bom-mcp will try ~/.openclaw/openclaw.json -> browser.cdpUrl.
# BOM_MCP_DIGIKEY_CDP_URL=http://127.0.0.1:9222
# BOM_MCP_OPENCLAW_CONFIG_PATH=$HOME/.openclaw/openclaw.json
#
# Example IC Net logged-in session:
# BOM_MCP_WEB_IC_NET_COOKIE=PHPSESSID=...; ICNet[Host]=https%3A%2F%2Fwww.ic.net.cn
# Example ICkey override headers:
# BOM_MCP_WEB_ICKEY_CN_REFERER=https://www.ickey.cn/
# Example DigiKey browser session:
# BOM_MCP_WEB_DIGIKEY_CN_COOKIE=cf_clearance=...; _abck=...
BOM_MCP_DIGIKEY_CDP_URL=
BOM_MCP_OPENCLAW_CONFIG_PATH=
BOM_MCP_WEB_USER_AGENT=
BOM_MCP_WEB_COOKIE=
BOM_MCP_WEB_HEADERS_JSON=
BOM_MCP_WEB_DIGIKEY_CN_COOKIE=
BOM_MCP_WEB_DIGIKEY_CN_USER_AGENT=
BOM_MCP_WEB_DIGIKEY_CN_REFERER=
BOM_MCP_WEB_DIGIKEY_CN_HEADERS_JSON=
BOM_MCP_WEB_ICKEY_CN_COOKIE=
BOM_MCP_WEB_ICKEY_CN_USER_AGENT=
BOM_MCP_WEB_ICKEY_CN_REFERER=
BOM_MCP_WEB_ICKEY_CN_HEADERS_JSON=
BOM_MCP_WEB_IC_NET_COOKIE=
BOM_MCP_WEB_IC_NET_USER_AGENT=
BOM_MCP_WEB_IC_NET_REFERER=
BOM_MCP_WEB_IC_NET_HEADERS_JSON=
