{
  "name": "clawos-web",
  "private": true,
  "type": "module",
  "scripts": {
    "tailwind:build": "tailwindcss -c tailwind.config.mjs -i src/styles/input.css -o dist/output.css --minify",
    "tailwind:watch": "tailwindcss -c tailwind.config.mjs -i src/styles/input.css -o dist/output.css --watch",
    "dev": "bun run tailwind:watch & bun --watch src/index.ts",
    "start": "bun run tailwind:build && bun run src/index.ts",
    "test": "bun test",
    "pm2:start": "pm2 start ecosystem.config.cjs --only clawos",
    "pm2:restart": "pm2 restart clawos",
    "pm2:logs": "pm2 logs clawos"
  },
  "dependencies": {
    "hono": "^4.10.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "daisyui": "^5.5.18",
    "tailwindcss": "^4.1.18"
  }
}
