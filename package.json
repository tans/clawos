{
  "name": "clawos",
  "version": "0.2.5",
  "type": "module",
  "scripts": {
    "tailwind:build": "tailwindcss -i src/styles/input.css -o dist/output.css --minify",
    "dev": "bun run tailwind:build && bun --watch src/server.ts",
    "build": "bun run build:exe",
    "publish": "bun run publish:clawos",
    "publish:json": "bun run scripts/publish-clawos.ts --skip-installer",
    "start": "bun run src/server.ts",
    "test": "bun test",
    "publish:clawos": "bun run scripts/publish-clawos.ts",
    "build:exe": "bun run scripts/build-clawos.ts"
  },
  "dependencies": {
    "json5": "^2.2.3",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.16",
    "daisyui": "^5.5.18",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.1.16"
  }
}
