{
  "name": "clawos",
  "version": "0.9.21",
  "type": "module",
  "scripts": {
    "tailwind:build": "tailwindcss -i src/styles/input.css -o dist/output.css --minify",
    "tailwind:watch": "tailwindcss -i src/styles/input.css -o dist/output.css --watch=always",
    "dev": "bun run desktop:dev",
    "electrobun:dev": "bun run scripts/electrobun.ts dev",
    "electrobun:dev:watch": "bun run scripts/electrobun.ts dev --watch",
    "electrobun:build": "bun run scripts/electrobun.ts build --env=dev",
    "electrobun:build:dev": "bun run scripts/electrobun.ts build --env=dev",
    "electrobun:build:stable": "bun run scripts/electrobun.ts build --env=stable",
    "electrobun:download": "bun run scripts/download-electrobun-assets.ts",
    "icon:windows": "bun run scripts/generate-windows-icon.ts",
    "desktop:dev": "bun run scripts/desktop-dev.ts",
    "desktop:dev:raw": "bun run tailwind:build && CLAWOS_DESKTOP_DEV=1 bun run electrobun:dev:watch",
    "desktop:build": "bun run tailwind:build && bun run electrobun:build",
    "desktop:build:dev": "bun run tailwind:build && bun run scripts/electrobun.ts build --env=dev",
    "desktop:build:setup": "bun run tailwind:build && bun run scripts/electrobun.ts build --env=stable",
    "desktop:build:canary": "bun run tailwind:build && bun run scripts/electrobun.ts build --env=canary",
    "desktop:build:stable": "bun run tailwind:build && bun run scripts/electrobun.ts build --env=stable",
    "build": "bun run desktop:build",
    "freegpt:dev": "bun --watch freegpt/src/index.ts",
    "freegpt:start": "bun run freegpt/src/index.ts",
    "publish": "bun run scripts/publish-clawos.ts",
    "publish:all": "bun run scripts/publish-clawos.ts",
    "publish:installer": "bun run scripts/publish-clawos.ts --skip-config",
    "publish:config": "bun run scripts/publish-clawos.ts --skip-installer",
    "publish:json": "bun run scripts/publish-clawos.ts --skip-installer",
    "release": "bun run scripts/release-clawos.ts --env=stable",
    "release:stable": "bun run scripts/release-clawos.ts --env=stable",
    "release:canary": "bun run scripts/release-clawos.ts --env=canary",
    "release:dev": "bun run scripts/release-clawos.ts --env=dev",
    "start": "bun run tailwind:build && bun run electrobun:dev",
    "test": "bun test"
  },
  "dependencies": {
    "json5": "^2.2.3",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.16",
    "daisyui": "^5.5.18",
    "electrobun": "^1.13.1",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.1.16"
  }
}
