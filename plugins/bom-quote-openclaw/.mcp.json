{
  "mcpServers": {
    "bom-mcp": {
      "command": "bun",
      "args": [
        "__BOM_MCP_ENTRY__",
        "serve",
        "--transport",
        "stdio"
      ],
      "env": {
        "BOM_MCP_STATE_DIR": "__BOM_MCP_STATE_DIR__",
        "BOM_MCP_DB_PATH": "__BOM_MCP_DB_PATH__",
        "BOM_MCP_EXPORT_DIR": "__BOM_MCP_EXPORT_DIR__",
        "BOM_MCP_CACHE_DIR": "__BOM_MCP_CACHE_DIR__",
        "BOM_MCP_FX_USD_CNY": "7.2",
        "BOM_MCP_DIGIKEY_CDP_URL": ""
      }
    }
  }
}
