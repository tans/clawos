{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawos.dev/schemas/mcp-lowcode.schema.json",
  "title": "ClawOS MCP Low-code Panel Schema",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "clawos/v1"
    },
    "kind": {
      "type": "string",
      "const": "MCPPanel"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "spec": {
      "$ref": "#/$defs/spec"
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "title"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "icon": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40
          },
          "maxItems": 20,
          "uniqueItems": true
        }
      }
    },
    "spec": {
      "type": "object",
      "required": [
        "visibility",
        "status",
        "views",
        "actions"
      ],
      "additionalProperties": false,
      "properties": {
        "visibility": {
          "$ref": "#/$defs/visibility"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "views": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/view"
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          }
        },
        "components": {
          "$ref": "#/$defs/components"
        }
      }
    },
    "visibility": {
      "type": "object",
      "required": [
        "enabled",
        "environments"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "environments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "dev",
              "staging",
              "prod"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "status": {
      "type": "object",
      "required": [
        "source",
        "fields"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "health_endpoint",
            "runtime_registry",
            "static"
          ]
        },
        "endpoint": {
          "type": "string",
          "pattern": "^/"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statusField"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "source": {
                "const": "health_endpoint"
              }
            }
          },
          "then": {
            "required": [
              "endpoint"
            ]
          }
        }
      ]
    },
    "statusField": {
      "type": "object",
      "required": [
        "key",
        "label",
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "badge",
            "datetime",
            "number",
            "boolean"
          ]
        }
      }
    },
    "view": {
      "type": "object",
      "required": [
        "id",
        "title",
        "blocks"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-_]{1,31}$"
        },
        "title": {
          "type": "string"
        },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/block"
          }
        }
      }
    },
    "block": {
      "oneOf": [
        {
          "$ref": "#/$defs/keyValueBlock"
        },
        {
          "$ref": "#/$defs/markdownBlock"
        },
        {
          "$ref": "#/$defs/formBlock"
        },
        {
          "$ref": "#/$defs/tableBlock"
        }
      ]
    },
    "keyValueBlock": {
      "type": "object",
      "required": [
        "type",
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "key_value"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "markdownBlock": {
      "type": "object",
      "required": [
        "type",
        "source",
        "content"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "markdown"
        },
        "source": {
          "type": "string",
          "const": "static"
        },
        "content": {
          "type": "string"
        }
      }
    },
    "tableBlock": {
      "type": "object",
      "required": [
        "type",
        "source",
        "columns"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "table"
        },
        "source": {
          "type": "string"
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/tableColumn"
          }
        }
      }
    },
    "tableColumn": {
      "type": "object",
      "required": [
        "key",
        "label"
      ],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "formBlock": {
      "type": "object",
      "required": [
        "type",
        "submitAction",
        "fields"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "form"
        },
        "submitAction": {
          "type": "string"
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/formField"
          }
        }
      }
    },
    "formField": {
      "type": "object",
      "required": [
        "name",
        "label",
        "component"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "component": {
          "type": "string",
          "enum": [
            "input",
            "number",
            "select",
            "switch",
            "textarea",
            "json_editor"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "default": {
          "type": [
            "string",
            "number",
            "boolean",
            "object",
            "array",
            "null"
          ]
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fieldRule"
          }
        }
      }
    },
    "fieldRule": {
      "type": "object",
      "required": [
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "url",
            "min",
            "max",
            "regex"
          ]
        },
        "value": {
          "type": [
            "number",
            "string"
          ]
        }
      }
    },
    "action": {
      "type": "object",
      "required": [
        "id",
        "label",
        "type",
        "executor"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-_]{1,31}$"
        },
        "label": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "lifecycle",
            "config",
            "observe",
            "custom"
          ]
        },
        "executor": {
          "type": "string",
          "minLength": 1
        },
        "confirm": {
          "type": "boolean"
        },
        "payloadSchemaRef": {
          "type": "string",
          "pattern": "^#/components/schemas/"
        }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schemas": {
          "type": "object",
          "additionalProperties": {
            "type": "object"
          }
        }
      }
    }
  }
}