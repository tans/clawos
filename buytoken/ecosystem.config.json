{
  "apps": [
    {
      "name": "buytoken",
      "cwd": "/root/buytoken",
      "script": "/root/.bun/bin/bun",
      "args": "run src/index.ts",
      "env": {
        "PORT": 26450,
        "NODE_ENV": "production"
      },
      "autorestart": true,
      "watch": false,
      "merge_logs": true,
      "time": true,
      "out_file": "logs/buytoken.out.log",
      "error_file": "logs/buytoken.err.log"
    }
  ]
}
