{
  "name": "clawos-app",
  "version": "0.9.44",
  "private": true,
  "type": "module",
  "scripts": {
    "webview": "vite --config vite.config.ts",
    "webview:dev": "bun run webview",
    "webview:build": "bun run webview -- build",
    "webview:watch": "bun run webview -- build --watch",
    "dev": "bun run desktop:dev",
    "electrobun": "bun run scripts/electrobun.ts",
    "electrobun:dev": "bun run electrobun -- dev",
    "electrobun:dev:watch": "bun run electrobun -- dev --watch",
    "electrobun:build": "bun run electrobun -- build --env=dev",
    "electrobun:download": "bun run scripts/download-electrobun-assets.ts",
    "icon:windows": "bun run scripts/generate-windows-icon.ts",
    "desktop:dev": "bun run scripts/desktop-dev.ts",
    "desktop:dev:raw": "bun run webview:build && CLAWOS_DESKTOP_DEV=1 bun run electrobun:dev:watch",
    "desktop:build": "bun run webview:build && bun run electrobun:build",
    "build": "bun run desktop:build",
    "start": "bun run webview:build && bun run electrobun:dev",
    "test": "cd .. && bun test",
    "publish": "bun run ../scripts/publish-clawos.ts --config=clawos_xiake.json"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "json5": "^2.2.3",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electrobun": "^1.16.0",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
